#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
JAR_PATH="${ROOT_DIR}/target/sofa-rpcctl.jar"

if [[ ! -f "${JAR_PATH}" ]]; then
  echo "Missing ${JAR_PATH}. Run ./scripts/build.sh first." >&2
  exit 1
fi

cd "${ROOT_DIR}"
exec java -jar "${JAR_PATH}" "$@"
